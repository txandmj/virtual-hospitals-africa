{
  "tasks": {
    "chatbot:patient": "deno task run:trusted chatbot/chatbot.ts patient",
    "chatbot:pharmacist": "mkdir -p temp_files && deno task run:trusted chatbot/chatbot.ts pharmacist",
    "build": "NO_EXTERNAL_CONNECT=1 vite build && deno run -A scripts/fix_fresh_route_order.ts",
    "vite": "vite",
    "proxy": "NO_MONKEY_PATCH_CONSOLE=1 deno task run:trusted proxy.ts",
    "start": "./scripts/dev.sh",
    "dev": "./scripts/dev.sh",
    "start:docker": "docker compose up -d",
    "start:beep": "./scripts/watch_and_beep.sh '(Error|error)' deno start",
    "rebuild": "rm -rf /_fresh && rm -rf node_modules && deno task lock:reset && deno task build",
    "web": "./scripts/web.sh",
    "db:codegen": "./db/codegen.sh",
    "db:local": "./db/local.sh",
    "db:docker": "./db/docker.sh",
    "db:migrate": "SLOW_QUERY_THRESHOLD_MS=30000 deno task run:trusted db/migrate.ts",
    "db:seed": "SLOW_QUERY_THRESHOLD_MS=30000 deno task run:trusted db/seed/run.ts",
    "db:drop": "deno task run:trusted db/drop.ts",
    "db:dump": "deno task run:trusted db/dump.ts",
    "db:rebuild": "deno task db:migrate to snomed_concept_active_descendants_realized && deno task db:migrate latest && deno task db:seed load && deno task db:codegen",
    "db:reset": "deno task run:trusted ./db/reset.ts",
    "db:restore": "deno task run:trusted db/restore.ts",
    "db:recreate": "deno task run:trusted db/recreate.ts",
    "db:create": "deno task run:trusted db/create.ts",
    "db:demo": "deno task db:local reset && deno task run:trusted ./scripts/seed/add_dummy_data.ts",
    "db:stage:snomed": "deno task db:drop && deno task db:create && deno task db:migrate to snomed_concept_active_descendants_realized && deno task db:seed load 01_icd10 && deno task db:seed load 02_snomed_base && deno task db:seed load 03_snomed_inferred && deno task db:seed load 04_snomed_concept_active_descendants_realized && rm -f ./db/dumps/snomed && deno task db:dump > ./db/dumps/snomed",
    "db:dummy": "deno task run:trusted ./scripts/seed/add_dummy_data.ts",
    "events:processor": "deno task run:trusted events/processor.ts",
    "docker": "./scripts/env/docker.sh",
    "local": "./scripts/env/local.sh",
    "prod": "./scripts/env/prod.sh",
    "compile": "DENO_TLS_CA_STORE=system deno compile -A --unsafely-ignore-certificate-errors --unstable --target x86_64-unknown-linux-gnu",
    "compile:chatbot": "deno task compile --output binaries/chatbot chatbot/chatbot.ts",
    "compile:web": "deno task compile --output binaries/web main.ts",
    "compile:s_expressions": "deno task script ./s_expression/compile.ts",
    "compile:blog": "deno task run:trusted scripts/compile_blog.ts",
    "lock:reset": "./scripts/file-manipulation/lock_reset.sh",
    "rm_unused_imports": "deno task script remove-unused-imports",
    "repl": "DENO_TLS_CA_STORE=system deno repl -A --unsafely-ignore-certificate-errors --unstable-temporal --env --eval-file=repl.ts",
    "run:trusted": "DENO_TLS_CA_STORE=system deno run -A --unstable-temporal --env --unsafely-ignore-certificate-errors",
    "script": "./scripts/run_script.sh",
    "switch:prod": "cp .env.prod .env && echo '\n' >> .env && cat .env.extra >> .env || true",
    "switch:local": "cp .env.local .env && echo '\n' >> .env && cat .env.extra >> .env || true",
    "switch:docker": "cp .env.docker .env && echo '\n' >> .env && cat .env.extra >> .env || true",
    "test": "./scripts/test/test.sh",
    "test:chatbot": "./scripts/test/chatbot.sh",
    "test:one": "rm -f test_server.log && deno task db:migrate:check && DENO_TLS_CA_STORE=system IS_TEST=true deno test -A --unstable-temporal --env --unsafely-ignore-certificate-errors",
    "test:watch": "./scripts/watch_and_beep.sh FAILED deno task test --watch",
    "tmux": "./scripts/dev-environment/tmux.sh",
    "preview": "deno serve -A _fresh/server.js",
    "check": "./scripts/code-quality/check.sh",
    "hygiene": "./scripts/code-quality/hygiene.sh",
    "util": "deno task run:trusted ./util.ts",
    "rules:rebuild": "deno task compile:s_expressions && deno task docker db:seed recreate 31_rules && deno task db:seed dump 31_rules",
    "rules:rebuild:prod": "deno task rules:rebuild && deno task prod db:seed reload 31_rules",
    "dummyx": "triggerdockerrebuild"
  },
  "compilerOptions": { 
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": [
      "vite/client"
    ]
  },
  "fmt": {
    "indentWidth": 2,
    "semiColons": false,
    "singleQuote": true,
    "lineWidth": 160,
    "proseWrap": "preserve",
    "include": ["**/*.ts", "**/*.tsx"]
  },
  "lint": {
    "rules": { "include": ["no-unused-vars"], "tags": ["fresh", "recommended"] }
  },
  "imports": {
    "@deno/loader": "jsr:@deno/loader@0.5.0",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "test/_helpers/": "./test/_helpers/",
    "@headlessui/react": "npm:@headlessui/react@2.2.9",
    "@preact/signals": "npm:@preact/signals@^2.5.0",
    "@std/cli": "jsr:@std/cli@0.224.7",
    "@tailwindcss/forms": "npm:@tailwindcss/forms@0.5.7",
    "@tailwindcss/typography": "npm:@tailwindcss/typography@0.5.16",
    "awesome-phonenumber": "npm:awesome-phonenumber@7.2.0",
    "cheerio": "npm:cheerio@1.1.2",
    "csv": "https://deno.land/x/csv@v0.8.0/mod.ts",
    "decimal": "npm:decimal.js-light@2.5.1",
    "fast-levenshtein": "npm:fast-levenshtein@3.0.0",
    "@types/fast-levenshtein": "npm:@types/fast-levenshtein@0.0.4",
    "fast-xml-parser": "npm:fast-xml-parser@4.3.4",
    "fracturedjsonjs": "npm:fracturedjsonjs@5.0.1",
    "kysely": "npm:kysely@0.28.8",
    "natural": "npm:natural@6.10.4",
    "pg": "npm:pg@8.16.0",
    "@types/pg": "npm:@types/pg@8.16.0",
    "pg-cursor": "npm:pg-cursor@2.15.3",
    "@types/pg-cursor": "npm:@types/pg-cursor@2.7.2",
    "marked": "npm:marked@18.0.0",
    "pdfjs-dist": "npm:pdfjs-dist@4.10.38",
    "preact": "npm:preact@10.27.2",
    "preact/": "npm:/preact@10.27.2/",
    "prompt": "jsr:@cliffy/prompt@1.0.0-rc.7",
    "puppeteer": "npm:puppeteer@24.40.0",
    "react": "npm:/preact@10.27.2/compat",
    "redis": "https://deno.land/x/redis@v0.25.5/mod.ts",
    "redlock": "https://deno.land/x/redlock@v1.0/mod.ts",
    "react-sparklines": "npm:react-sparklines@1.7.0",
    "spinners": "https://raw.githubusercontent.com/will-weiss/spinners/refs/heads/master/mod.ts",
    "std/": "https://deno.land/std@0.224.0/",
    "sql-formatter": "npm:sql-formatter@15.6.9",
    "tailwind-merge": "npm:tailwind-merge@2.6.0",
    "tiny-lru": "npm:tiny-lru@11.4.5",
    "zod": "npm:zod@4.2.1",
    "fresh": "jsr:@fresh/core@2.2.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@1.0.8",
    "s-expression": "npm:s-expression@3.1.1",
    "vite": "npm:vite@^7.1.3",
    "tailwindcss": "npm:tailwindcss@4.1.18",
    "tailwindcss/plugin": "npm:/tailwindcss@4.1.10/plugin.js",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@4.1.12",
    "patch-package": "npm:patch-package@latest",
    "html": "npm:html@latest",
    "@types/html": "npm:@types/html@latest",
    "rollup": "npm:rollup@4.53.0",
    "marked": "npm:marked@15.0.7"
  },
  "exclude": ["**/_fresh/*"],
  "nodeModulesDir": "manual"
}
