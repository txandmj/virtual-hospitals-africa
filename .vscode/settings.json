{
  "deno.enable": true,
  "deno.lint": true,
  "deno.testing.args": ["--allow-all"],
  "deno.codeLens.test": true,
  "deno.codeLens.testArgs": [
    "--allow-all"
  ],
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.hg/store/**": true,
    "**/.git/**": true,
    "**/node_modules/**": true,
    "**/.vscode/**": true
  }
}