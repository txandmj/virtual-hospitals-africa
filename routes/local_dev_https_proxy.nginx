http {
  server {
    listen 8000 ssl;
    server_name localhost;

    ssl_certificate /local-certs/localhost.crt;
    ssl_certificate_key /local-certs/localhost.key;

    location / {
      proxy_pass http://localhost:3000;
      proxy_set_header Host $host;
      proxy_set_header X-Real-IP $remote_addr;
    }
  }
}
