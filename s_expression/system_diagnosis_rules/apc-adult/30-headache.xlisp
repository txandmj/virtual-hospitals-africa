;; Page 30 – Headache
(system_diagnosis_rule
  "Diagnose Migraine likely "
  (diagnosis
    (snomed_concept "Migraine" "disorder")
    probable 
  )
  adult
    (clinical_finding (snomed_concept "Fever" "finding" "Absent" "qualifier value")
    (clinical_finding (snomed_concept "Generalized acute body pains" "finding" "Absent" "qualifier value")
    (clinical_finding (snomed_concept "Common cold" "disorder" "Recent’ "qualifier value" "Absent" "qualifier value")
    (clinical_finding (snomed_concept "Throbbing headache" "finding" "Recurrent" "qualifier value")
    (clinical_finding (snomed_concept "Chronic headache disorder" "disorder" "Nausea" "finding")
    (clinical_finding (snomed_concept "Chronic headache disorder" "disorder" "Eyes sensitive to light" "finding")
    (clinical_finding (snomed_concept "Chronic headache   disorder" "disorder" "Noise intolerance" "finding")
    (clinical_finding (snomed_concept "Headache" "finding" "Resolved" "qualifier value" "In" (attribute) "hour" "qualifier value" 72))
  )
)
;; Page 30 – Headache
(system_diagnosis_rule
  "Diagnose Tension headache likely"
  (diagnosis
    (snomed_concept "Tension-type headache" "disorder")
    probable
  )
  (adult
    (clinical_finding (snomed_concept "Generalized headache" "finding")     (clinical_finding (snomed_concept "Dull pain" "finding")
    (clinical_finding (snomed_concept "Generalized headache" "finding")     (clinical_finding (snomed_concept "Tightening pain" "finding")
    (clinical_finding (snomed_concept "Generalized headache" "finding")     (clinical_finding (snomed_concept "Heavy head" "finding")
    (clinical_finding (snomed_concept "Generalized headache" "finding")     (clinical_finding (snomed_concept "Crushing pain" "finding")
  )
)
