(system_diagnosis_rule
  "Diagnose Giant cell arteritis likely"
  (diagnosis
    (snomed_concept "Giant cell arteritis" "disorder"
    probable
  )
  (adult
    (> (clinical_finding (snomed_concept " Current chronological age" (observable entity) "year" "qualifier value"50))
    (clinical_finding (snomed_concept "Temporal headache" "finding")